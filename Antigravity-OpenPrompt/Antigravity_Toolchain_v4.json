[
    {
        "name": "task_boundary",
        "description": "Indicate the start of a task or make an update to the current task. CRITICAL: Use this as the VERY FIRST tool in every turn. Describe what you WILL do next in TaskStatus.",
        "parameters": {
            "type": "OBJECT",
            "properties": {
                "TaskName": { "type": "STRING", "description": "High-level goal name." },
                "Mode": { "type": "STRING", "description": "PLANNING, EXECUTION, or VERIFICATION." },
                "TaskSummary": { "type": "STRING", "description": "Cumulative summary of accomplishments." },
                "TaskStatus": { "type": "STRING", "description": "NEXT activity description (future tense)." },
                "PredictedTaskSize": { "type": "INTEGER", "description": "Estimate of remaining tool calls." }
            },
            "required": ["TaskName", "Mode", "TaskSummary", "TaskStatus", "PredictedTaskSize"]
        }
    },
    {
        "name": "notify_user",
        "description": "Communicate with the user. Use this to request review of patches or if tool calls fail repeatedly.",
        "parameters": {
            "type": "OBJECT",
            "properties": {
                "Message": { "type": "STRING" },
                "PathsToReview": { "type": "ARRAY", "items": { "type": "STRING" } },
                "BlockedOnUser": { "type": "BOOLEAN" },
                "ShouldAutoProceed": { "type": "BOOLEAN" }
            },
            "required": ["Message", "PathsToReview", "BlockedOnUser", "ShouldAutoProceed"]
        }
    },
    {
        "name": "run_command",
        "description": "Execute a shell command. 1.20 SAFETY PROTOCOL: 1. ALWAYS wrap long-running or potentially hanging commands in 'timeout <SECONDS>'. 2. Use 'WaitMsBeforeAsync: 5000' or higher to force synchronous output capture. 3. Prefer small, atomic commands.",
        "parameters": {
            "type": "OBJECT",
            "properties": {
                "CommandLine": { "type": "STRING", "description": "Command to run. Use 'timeout 60' for safety unless it must run longer." },
                "Cwd": { "type": "STRING" },
                "SafeToAutoRun": { "type": "BOOLEAN" },
                "WaitMsBeforeAsync": { "type": "INTEGER", "description": "Set to 5000+ for stable output capture in 1.20." }
            },
            "required": ["Cwd", "WaitMsBeforeAsync", "SafeToAutoRun", "CommandLine"]
        }
    },
    {
        "name": "command_status",
        "description": "Check background command output. RULE: If a command is 'RUNNING' but the tail output is stale, it may be dead. Use 'send_command_input' with 'Terminate: true' to recover.",
        "parameters": {
            "type": "OBJECT",
            "properties": {
                "CommandId": { "type": "STRING" },
                "WaitDurationSeconds": { "type": "INTEGER" },
                "OutputCharacterCount": { "type": "INTEGER" }
            },
            "required": ["CommandId", "WaitDurationSeconds"]
        }
    },
    {
        "name": "view_file",
        "parameters": {
            "type": "OBJECT",
            "properties": {
                "AbsolutePath": { "type": "STRING" },
                "StartLine": { "type": "INTEGER" },
                "EndLine": { "type": "INTEGER" }
            },
            "required": ["AbsolutePath"]
        }
    },
    {
        "name": "list_dir",
        "parameters": {
            "type": "OBJECT",
            "properties": {
                "DirectoryPath": { "type": "STRING" }
            },
            "required": ["DirectoryPath"]
        }
    },
    {
        "name": "write_to_file",
        "parameters": {
            "type": "OBJECT",
            "properties": {
                "TargetFile": { "type": "STRING" },
                "CodeContent": { "type": "STRING" },
                "Overwrite": { "type": "BOOLEAN" },
                "IsArtifact": { "type": "BOOLEAN" }
            },
            "required": ["TargetFile", "CodeContent", "Overwrite", "IsArtifact"]
        }
    },
    {
        "name": "replace_file_content",
        "parameters": {
            "type": "OBJECT",
            "properties": {
                "TargetFile": { "type": "STRING" },
                "TargetContent": { "type": "STRING" },
                "ReplacementContent": { "type": "STRING" },
                "StartLine": { "type": "INTEGER" },
                "EndLine": { "type": "INTEGER" }
            },
            "required": ["TargetFile", "TargetContent", "ReplacementContent", "StartLine", "EndLine"]
        }
    },
    {
        "name": "multi_replace_file_content",
        "parameters": {
            "type": "OBJECT",
            "properties": {
                "TargetFile": { "type": "STRING" },
                "ReplacementChunks": { "type": "ARRAY", "items": { "type": "OBJECT", "properties": { "TargetContent": { "type": "STRING" }, "ReplacementContent": { "type": "STRING" }, "StartLine": { "type": "INTEGER" }, "EndLine": { "type": "INTEGER" } } } }
            },
            "required": ["TargetFile", "ReplacementChunks"]
        }
    },
    {
        "name": "grep_search",
        "parameters": {
            "type": "OBJECT",
            "properties": {
                "SearchPath": { "type": "STRING" },
                "Query": { "type": "STRING" },
                "IsRegex": { "type": "BOOLEAN" }
            },
            "required": ["SearchPath", "Query"]
        }
    }
]
