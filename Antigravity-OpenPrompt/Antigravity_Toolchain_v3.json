[
    {
        "name": "task_boundary",
        "description": "Indicate the start of a task or make an update to the current task. CRITICAL: Use this to track state. IMPORTANT: Describe what you WILL do next in TaskStatus.",
        "parameters": {
            "type": "OBJECT",
            "properties": {
                "TaskName": { "type": "STRING", "description": "High-level objective name." },
                "Mode": { "type": "STRING", "description": "PLANNING, EXECUTION, or VERIFICATION." },
                "TaskSummary": { "type": "STRING", "description": "Past tense summary of accomplishments." },
                "TaskStatus": { "type": "STRING", "description": "Future tense description of NEXT steps." },
                "PredictedTaskSize": { "type": "INTEGER", "description": "Estimate of remaining tool calls." }
            },
            "required": ["TaskName", "Mode", "TaskSummary", "TaskStatus", "PredictedTaskSize"]
        }
    },
    {
        "name": "notify_user",
        "description": "Communicate with the user. Use this to ask for review of patches or if a command is truly stuck.",
        "parameters": {
            "type": "OBJECT",
            "properties": {
                "Message": { "type": "STRING" },
                "PathsToReview": { "type": "ARRAY", "items": { "type": "STRING" } },
                "BlockedOnUser": { "type": "BOOLEAN" },
                "ShouldAutoProceed": { "type": "BOOLEAN" }
            },
            "required": ["Message", "PathsToReview", "BlockedOnUser", "ShouldAutoProceed"]
        }
    },
    {
        "name": "run_command",
        "description": "Execute a shell command. SAFETY RULES for Antigravity 1.20: 1. ALWAYS wrap potentially long commands in 'timeout <SECONDS>'. 2. Use 'WaitMsBeforeAsync: 5000' or higher to ensure capture of output before backgrounding. 3. Prefer atomic commands that exit quickly.",
        "parameters": {
            "type": "OBJECT",
            "properties": {
                "CommandLine": { "type": "STRING", "description": "The command. Wrap in 'timeout 300' if uncertain of exit speed." },
                "Cwd": { "type": "STRING" },
                "SafeToAutoRun": { "type": "BOOLEAN" },
                "WaitMsBeforeAsync": { "type": "INTEGER", "description": "Use 5000+ for stable output capture." }
            },
            "required": ["Cwd", "WaitMsBeforeAsync", "SafeToAutoRun", "CommandLine"]
        }
    },
    {
        "name": "command_status",
        "description": "Check background command. Rule: If a command is 'RUNNING' without output for >30s, assume it is stuck and consider send_command_input with Terminate: true.",
        "parameters": {
            "type": "OBJECT",
            "properties": {
                "CommandId": { "type": "STRING" },
                "WaitDurationSeconds": { "type": "INTEGER" },
                "OutputCharacterCount": { "type": "INTEGER" }
            },
            "required": ["CommandId", "WaitDurationSeconds"]
        }
    },
    {
        "name": "send_command_input",
        "parameters": {
            "type": "OBJECT",
            "properties": {
                "CommandId": { "type": "STRING" },
                "Input": { "type": "STRING" },
                "SafeToAutoRun": { "type": "BOOLEAN" },
                "Terminate": { "type": "BOOLEAN", "description": "Set to true to force-kill a non-exitable command." },
                "WaitMs": { "type": "INTEGER" }
            },
            "required": ["CommandId", "WaitMs", "SafeToAutoRun"]
        }
    },
    { "name": "view_file", "parameters": { "type": "OBJECT", "properties": { "AbsolutePath": { "type": "STRING" }, "StartLine": { "type": "INTEGER" }, "EndLine": { "type": "INTEGER" } }, "required": ["AbsolutePath"] } },
    { "name": "list_dir", "parameters": { "type": "OBJECT", "properties": { "DirectoryPath": { "type": "STRING" } }, "required": ["DirectoryPath"] } },
    { "name": "write_to_file", "parameters": { "type": "OBJECT", "properties": { "TargetFile": { "type": "STRING" }, "CodeContent": { "type": "STRING" }, "Overwrite": { "type": "BOOLEAN" }, "IsArtifact": { "type": "BOOLEAN" } }, "required": ["TargetFile", "CodeContent", "Overwrite", "IsArtifact"] } },
    { "name": "replace_file_content", "parameters": { "type": "OBJECT", "properties": { "TargetFile": { "type": "STRING" }, "TargetContent": { "type": "STRING" }, "ReplacementContent": { "type": "STRING" }, "StartLine": { "type": "INTEGER" }, "EndLine": { "type": "INTEGER" } }, "required": ["TargetFile", "TargetContent", "ReplacementContent", "StartLine", "EndLine"] } },
    { "name": "multi_replace_file_content", "parameters": { "type": "OBJECT", "properties": { "TargetFile": { "type": "STRING" }, "ReplacementChunks": { "type": "ARRAY", "items": { "type": "OBJECT", "properties": { "TargetContent": { "type": "STRING" }, "ReplacementContent": { "type": "STRING" }, "StartLine": { "type": "INTEGER" }, "EndLine": { "type": "INTEGER" } } } } }, "required": ["TargetFile", "ReplacementChunks"] } },
    { "name": "grep_search", "parameters": { "type": "OBJECT", "properties": { "SearchPath": { "type": "STRING" }, "Query": { "type": "STRING" }, "IsRegex": { "type": "BOOLEAN" } }, "required": ["SearchPath", "Query"] } }
]
