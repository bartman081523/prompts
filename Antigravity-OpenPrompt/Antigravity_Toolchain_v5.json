                "SafeToAutoRun": { "type": "BOOLEAN" },
                "WaitMsBeforeAsync": { "type": "INTEGER", "description": "Set to 10000 for maximum reliability in 1.20." }
            },
            "required": ["Cwd", "WaitMsBeforeAsync", "SafeToAutoRun", "CommandLine"]
        }
    },
    {
